              "type": "string"
            }
          },
          "type": "object"
        },
        "linksneighbors": {
          "properties": {
            "depth": {
              "default": 1,
              "description": "Maximum traversal depth",
              "type": "integer"
            },
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "max_nodes": {
              "default": 200,
              "description": "Maximum nodes to return",
              "type": "integer"
            },
            "min_confidence": {
              "default": "low",
              "description": "Minimum edge confidence (low, medium, high)",
              "type": "string"
            },
            "vault": {
              "default": ".",
              "description": "Path to vault root",
              "type": "string"
            }
          },
          "type": "object"
        },
        "lintfixlinks": {
          "properties": {
            "fix": {
              "default": false,
              "description": "Apply fixes (default is dry-run)",
              "type": "boolean"
            },
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "vault": {
              "default": ".",
              "description": "Path to vault root",
              "type": "string"
            }
          },
          "type": "object"
        },
        "log": {
          "properties": {
            "color_enabled": {
              "default": "auto",
              "description": "Enable colored console output (auto, true, false). Auto detects TTY.",
              "examples": [
                "true"
              ],
              "type": "string"
            },
            "console_level": {
              "default": "",
              "description": "Console log level (trace, debug, info, warn, error, fatal, panic). If empty, uses app.log_level.",
              "examples": [
                "info"
              ],
              "type": "string"
            },
            "file_compress": {
              "default": false,
              "description": "Compress rotated log files with gzip",
              "examples": [
                "true"
              ],
              "type": "boolean"
            },
            "file_enabled": {
              "default": false,
              "description": "Enable file logging to capture detailed logs",
              "examples": [
                "true"
              ],
              "type": "boolean"
            },
            "file_level": {
              "default": "debug",
              "description": "File log level (trace, debug, info, warn, error, fatal, panic)",
              "examples": [
                "debug"
              ],
              "type": "string"
            },
            "file_max_age": {
              "default": 28,
              "description": "Maximum number of days to retain old log files",
              "examples": [
                "28"
              ],
              "type": "integer"
            },
            "file_max_backups": {
              "default": 3,
              "description": "Maximum number of old log files to retain",
              "examples": [
                "3"
              ],
              "type": "integer"
            },
            "file_max_size": {
              "default": 100,
              "description": "Maximum size in megabytes before log file is rotated",
              "examples": [
                "100"
              ],
              "type": "integer"
            },
            "file_path": {
              "default": "./logs/vaultmind.log",
              "description": "Path to the log file (created with secure 0600 permissions)",
              "examples": [
                "/var/log/vaultmind/app.log"
              ],
              "type": "string"
            },
            "sampling_enabled": {
              "default": false,
              "description": "Enable log sampling for high-volume scenarios",
              "examples": [
                "true"
              ],
              "type": "boolean"
            },
            "sampling_initial": {
              "default": 100,
              "description": "Number of messages to log per second before sampling",
              "examples": [
                "100"
              ],
              "type": "integer"
            },
            "sampling_thereafter": {
              "default": 100,
              "description": "Number of messages to log thereafter per second",
              "examples": [
                "100"
              ],
              "type": "integer"
            }
          },
          "type": "object"
        },
        "log_level": {
          "default": "info",
          "description": "Logging level for the application (trace, debug, info, warn, error, fatal, panic). Used as console level if app.log.console_level is not set.",
          "examples": [
            "debug"
          ],
          "type": "string"
        },
        "memorycontextpack": {
          "properties": {
            "budget": {
              "default": 4096,

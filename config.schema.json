{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Configuration schema for ckeletin-go CLI applications. Generated from the config registry.",
  "properties": {
    "app": {
      "properties": {
        "apply": {
          "properties": {
            "commit": {
              "default": false,
              "description": "Stage and commit all changes",
              "type": "boolean"
            },
            "diff": {
              "default": false,
              "description": "Show unified diffs",
              "type": "boolean"
            },
            "dry_run": {
              "default": false,
              "description": "Preview without executing",
              "type": "boolean"
            },
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "vault": {
              "default": ".",
              "description": "Path to vault root",
              "type": "string"
            }
          },
          "type": "object"
        },
        "ask": {
          "properties": {
            "budget": {
              "default": 4000,
              "description": "Token budget for context-pack",
              "type": "integer"
            },
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "max_items": {
              "default": 8,
              "description": "Max context items",
              "type": "integer"
            },
            "search_limit": {
              "default": 5,
              "description": "Max search hits",
              "type": "integer"
            },
            "vault": {
              "default": ".",
              "description": "Path to vault root",
              "type": "string"
            }
          },
          "type": "object"
        },
        "check": {
          "properties": {
            "category": {
              "default": "",
              "description": "Filter to specific categories (comma-separated: environment,quality,architecture,security,dependencies,tests)",
              "examples": [
                "security,tests"
              ],
              "type": "string"
            },
            "fail_fast": {
              "default": false,
              "description": "Stop on first failed check",
              "examples": [
                "true"
              ],
              "type": "boolean"
            },
            "parallel": {
              "default": true,
              "description": "Run checks within each category in parallel (disable with --parallel=false)",
              "examples": [
                "false"
              ],
              "type": "boolean"
            },
            "timing": {
              "default": true,
              "description": "Show duration for each check in the output",
              "examples": [
                "false"
              ],
              "type": "boolean"
            },
            "verbose": {
              "default": false,
              "description": "Show verbose output including command details",
              "examples": [
                "true"
              ],
              "type": "boolean"
            }
          },
          "type": "object"
        },
        "dataviewlint": {
          "properties": {
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "vault": {
              "default": ".",
              "description": "Path to vault root",
              "type": "string"
            }
          },
          "type": "object"
        },
        "dataviewrender": {
          "properties": {
            "commit": {
              "default": false,
              "description": "Stage and commit",
              "type": "boolean"
            },
            "diff": {
              "default": false,
              "description": "Show unified diff",
              "type": "boolean"
            },
            "dry_run": {
              "default": false,
              "description": "Preview without writing",
              "type": "boolean"
            },
            "force": {
              "default": false,
              "description": "Override checksum mismatch",
              "type": "boolean"
            },
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "section_key": {
              "default": "",
              "description": "Section key to render",
              "type": "string"
            },
            "vault": {
              "default": ".",
              "description": "Path to vault root",
              "type": "string"
            }
          },
          "type": "object"
        },
        "docs": {
          "properties": {
            "output_file": {
              "default": "",
              "description": "Output file for documentation (defaults to stdout)",
              "examples": [
                "/path/to/output.md"
              ],
              "type": "string"
            },
            "output_format": {
              "default": "markdown",
              "description": "Output format for documentation (markdown, yaml)",
              "examples": [
                "yaml"
              ],
              "type": "string"
            }
          },
          "type": "object"
        },
        "doctor": {
          "properties": {
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "vault": {
              "default": ".",
              "description": "Path to vault root",
              "type": "string"
            }
          },
          "type": "object"
        },
        "experimentreport": {
          "properties": {
            "experiment": {
              "default": "",
              "description": "Experiment name to report on",
              "type": "string"
            },
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "k": {
              "default": 10,
              "description": "K value for Hit@K metric",
              "type": "integer"
            }
          },
          "type": "object"
        },
        "frontmatter": {
          "properties": {
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "vault": {
              "default": ".",
              "description": "Path to vault root",
              "type": "string"
            }
          },
          "type": "object"
        },
        "frontmattermerge": {
          "properties": {
            "allow_extra": {
              "default": false,
              "description": "Allow keys not in type schema",
              "type": "boolean"
            },
            "commit": {
              "default": false,
              "description": "Stage and commit after mutation",
              "type": "boolean"
            },
            "diff": {
              "default": false,
              "description": "Show unified diff",
              "type": "boolean"
            },
            "dry_run": {
              "default": false,
              "description": "Preview changes without writing",
              "type": "boolean"
            },
            "file": {
              "default": "",
              "description": "YAML file with fields to merge",
              "type": "string"
            },
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "vault": {
              "default": ".",
              "description": "Path to vault root",
              "type": "string"
            }
          },
          "type": "object"
        },
        "frontmatternormalize": {
          "properties": {
            "commit": {
              "default": false,
              "description": "Stage and commit after mutation",
              "type": "boolean"
            },
            "diff": {
              "default": false,
              "description": "Show unified diff",
              "type": "boolean"
            },
            "dry_run": {
              "default": false,
              "description": "Preview changes without writing",
              "type": "boolean"
            },
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "strip_time": {
              "default": false,
              "description": "Force all datetimes to date-only",
              "type": "boolean"
            },
            "vault": {
              "default": ".",
              "description": "Path to vault root",
              "type": "string"
            }
          },
          "type": "object"
        },
        "frontmatterset": {
          "properties": {
            "allow_extra": {
              "default": false,
              "description": "Allow keys not in type schema",
              "type": "boolean"
            },
            "commit": {
              "default": false,
              "description": "Stage and commit after mutation",
              "type": "boolean"
            },
            "diff": {
              "default": false,
              "description": "Show unified diff",
              "type": "boolean"
            },
            "dry_run": {
              "default": false,
              "description": "Preview changes without writing",
              "type": "boolean"
            },
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "vault": {
              "default": ".",
              "description": "Path to vault root",
              "type": "string"
            }
          },
          "type": "object"
        },
        "frontmatterunset": {
          "properties": {
            "commit": {
              "default": false,
              "description": "Stage and commit after mutation",
              "type": "boolean"
            },
            "diff": {
              "default": false,
              "description": "Show unified diff",
              "type": "boolean"
            },
            "dry_run": {
              "default": false,
              "description": "Preview changes without writing",
              "type": "boolean"
            },
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "vault": {
              "default": ".",
              "description": "Path to vault root",
              "type": "string"
            }
          },
          "type": "object"
        },
        "gitstatus": {
          "properties": {
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "vault": {
              "default": ".",
              "description": "Path to vault root",
              "type": "string"
            }
          },
          "type": "object"
        },
        "index": {
          "properties": {
            "embed": {
              "default": false,
              "description": "Compute and store embeddings for note bodies",
              "examples": [
                "true"
              ],
              "type": "boolean"
            },
            "full": {
              "default": false,
              "description": "Force full rebuild instead of incremental index",
              "examples": [
                "true"
              ],
              "type": "boolean"
            },
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "examples": [
                "true"
              ],
              "type": "boolean"
            },
            "model": {
              "default": "minilm",
              "description": "Embedding model: minilm (384d, fast) or bge-m3 (1024d, 3-in-1)",
              "examples": [
                "bge-m3"
              ],
              "type": "string"
            },
            "vault": {
              "default": ".",
              "description": "Path to the vault root directory",
              "examples": [
                "./my-vault"
              ],
              "type": "string"
            }
          },
          "type": "object"
        },
        "links": {
          "properties": {
            "edge_type": {
              "default": "",
              "description": "Filter by edge type",
              "type": "string"

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Configuration schema for vaultmind CLI applications. Generated from the config registry.",
  "properties": {
    "app": {
      "properties": {
        "apply": {
          "properties": {
            "commit": {
              "default": false,
              "description": "Stage and commit all changes",
              "type": "boolean"
            },
            "diff": {
              "default": false,
              "description": "Show unified diffs",
              "type": "boolean"
            },
            "dry_run": {
              "default": false,
              "description": "Preview without executing",
              "type": "boolean"
            },
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "vault": {
              "default": ".",
              "description": "Path to vault root",
              "type": "string"
            }
          },
          "type": "object"
        },
        "arc": {
          "properties": {
            "candidates": {
              "properties": {
                "json": {
                  "default": false,
                  "description": "Output in JSON format",
                  "type": "boolean"
                },
                "vault": {
                  "default": ".",
                  "description": "Path to vault root",
                  "type": "string"
                }
              },
              "type": "object"
            }
          },
          "type": "object"
        },
        "ask": {
          "properties": {
            "budget": {
              "default": 4000,
              "description": "Token budget for context-pack",
              "type": "integer"
            },
            "explain": {
              "default": false,
              "description": "Show per-lane RRF contributions for each hit",
              "type": "boolean"
            },
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "max_items": {
              "default": 8,
              "description": "Max context items",
              "type": "integer"
            },
            "pointers_only": {
              "default": false,
              "description": "Skip context-pack bodies; render only id+title+type pointers (forces ask-to-read loop instead of letting the preload satisfy curiosity)",
              "type": "boolean"
            },
            "preview": {
              "default": false,
              "description": "Render a one-line body snippet under each ranked hit; bridges --pointers-only (titles only) and the full context-pack output",
              "type": "boolean"
            },
            "quiet_on_nomatch": {
              "default": false,
              "description": "Print nothing when the top hit is at/below the noise floor (no_match). For ambient recall: inject silence instead of irrelevant pointers when the prompt is off-domain. Also skips the context-pack and access fan-out so off-domain prompts don't reinforce irrelevant notes.",
              "type": "boolean"
            },
            "read": {
              "default": "",
              "description": "Read the body of the named hit inline after the menu — accepts a 1-indexed rank (e.g. --read 2) or an exact id (e.g. --read concept-foo). Single-command shortcut for probe→read when you already know which hit from the titles",
              "type": "string"
            },
            "search_limit": {
              "default": 5,
              "description": "Max search hits",
              "type": "integer"
            },
            "vault": {
              "default": ".",
              "description": "Path to vault root",
              "type": "string"
            }
          },
          "type": "object"
        },
        "check": {
          "properties": {
            "category": {
              "default": "",
              "description": "Filter to specific categories (comma-separated: environment,quality,architecture,security,dependencies,tests)",
              "examples": [
                "security,tests"
              ],
              "type": "string"
            },
            "fail_fast": {
              "default": false,
              "description": "Stop on first failed check",
              "examples": [
                "true"
              ],
              "type": "boolean"
            },
            "parallel": {
              "default": true,
              "description": "Run checks within each category in parallel (disable with --parallel=false)",
              "examples": [
                "false"
              ],
              "type": "boolean"
            },
            "timing": {
              "default": true,
              "description": "Show duration for each check in the output",
              "examples": [
                "false"
              ],
              "type": "boolean"
            },
            "verbose": {
              "default": false,
              "description": "Show verbose output including command details",
              "examples": [
                "true"
              ],
              "type": "boolean"
            }
          },
          "type": "object"
        },
        "dataviewlint": {
          "properties": {
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "vault": {
              "default": ".",
              "description": "Path to vault root",
              "type": "string"
            }
          },
          "type": "object"
        },
        "dataviewrender": {
          "properties": {
            "commit": {
              "default": false,
              "description": "Stage and commit",
              "type": "boolean"
            },
            "diff": {
              "default": false,
              "description": "Show unified diff",
              "type": "boolean"
            },
            "dry_run": {
              "default": false,
              "description": "Preview without writing",
              "type": "boolean"
            },
            "force": {
              "default": false,
              "description": "Override checksum mismatch",
              "type": "boolean"
            },
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "section_key": {
              "default": "",
              "description": "Section key to render",
              "type": "string"
            },
            "vault": {
              "default": ".",
              "description": "Path to vault root",
              "type": "string"
            }
          },
          "type": "object"
        },
        "docs": {
          "properties": {
            "output_file": {
              "default": "",
              "description": "Output file for documentation (defaults to stdout)",
              "examples": [
                "/path/to/output.md"
              ],
              "type": "string"
            },
            "output_format": {
              "default": "markdown",
              "description": "Output format for documentation (markdown, yaml)",
              "examples": [
                "yaml"
              ],
              "type": "string"
            }
          },
          "type": "object"
        },
        "docs_commands": {
          "properties": {
            "output": {
              "default": "",
              "description": "Output file for the command reference (defaults to stdout)",
              "examples": [
                "internal/onboard/COMMANDS.md"
              ],
              "type": "string"
            }
          },
          "type": "object"
        },
        "doctor": {
          "properties": {
            "all": {
              "default": false,
              "description": "Diagnose every vault discovered under --root (multi-vault health)",
              "type": "boolean"
            },
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "root": {
              "default": ".",
              "description": "Root directory to discover vaults under when --all is set",
              "type": "string"
            },
            "summary": {
              "default": false,
              "description": "Print summary counts only (suppress per-link details)",
              "type": "boolean"
            },
            "vault": {
              "default": ".",
              "description": "Path to vault root",
              "type": "string"
            }
          },
          "type": "object"
        },
        "doctorheal": {
          "properties": {
            "dry_run": {
              "default": false,
              "description": "Preview repairs without writing (default applies)",
              "type": "boolean"
            },
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "vault": {
              "default": ".",
              "description": "Path to vault root",
              "type": "string"
            }
          },
          "type": "object"
        },
        "doctorhealwikilinks": {
          "properties": {
            "dry_run": {
              "default": false,
              "description": "Preview repairs without writing (default applies)",
              "type": "boolean"
            },
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "vault": {
              "default": ".",
              "description": "Path to vault root",
              "type": "string"
            }
          },
          "type": "object"
        },
        "experimentcompare": {
          "properties": {
            "caller": {
              "default": "",
              "description": "Restrict to a single caller label",
              "type": "string"
            },
            "event_type": {
              "default": "",
              "description": "Restrict to one event type (ask|search|context_pack); empty = all three",
              "type": "string"
            },
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "k": {
              "default": 10,
              "description": "K value for Jaccard@K (and the cap on list length used for Kendall's tau)",
              "type": "integer"
            },
            "per_event": {
              "default": false,
              "description": "Emit one row per event in addition to aggregates",
              "type": "boolean"
            },
            "session": {
              "default": "",
              "description": "Restrict to a single session ID",
              "type": "string"
            },
            "since": {
              "default": "",
              "description": "Only events at or after this RFC3339 timestamp",
              "type": "string"
            }
          },
          "type": "object"
        },
        "experimentreport": {
          "properties": {
            "experiment": {
              "default": "",
              "description": "Experiment name to report on",
              "type": "string"
            },
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "k": {
              "default": 10,
              "description": "K value for Hit@K metric",
              "type": "integer"
            }
          },
          "type": "object"
        },
        "experimentsummary": {
          "properties": {
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "top": {
              "default": 10,
              "description": "Number of top-recalled notes to show",
              "type": "integer"
            }
          },
          "type": "object"
        },
        "experimenttrace": {
          "properties": {
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "note": {
              "default": "",
              "description": "Note ID to trace across sessions",
              "type": "string"
            },
            "session": {
              "default": "",
              "description": "Session ID to trace",
              "type": "string"
            }
          },
          "type": "object"
        },
        "export": {
          "properties": {
            "output": {
              "default": "",
              "description": "Output file path (empty = stdout)",
              "type": "string"
            },
            "preview": {
              "default": false,
              "description": "Print a human-readable summary instead of writing the JSON payload (useful for auditing before sharing)",
              "type": "boolean"
            },
            "rollup": {
              "default": false,
              "description": "Emit a federated-aggregator-shaped rollup (vault fingerprint + features + variant stats) instead of raw events",
              "type": "boolean"
            },
            "tier": {
              "default": "",
              "description": "Override telemetry tier (off|anonymous|full); empty = use experiments.telemetry from config",
              "type": "string"
            },
            "vault": {
              "default": ".",
              "description": "Vault path (required when --rollup is set; reads index DB and fingerprint)",
              "type": "string"
            }
          },
          "type": "object"
        },
        "frontmatter": {
          "properties": {
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "live": {
              "default": false,
              "description": "Validate raw .md files on disk instead of the indexed database",
              "type": "boolean"
            },
            "vault": {
              "default": ".",
              "description": "Path to vault root",
              "type": "string"
            }
          },
          "type": "object"
        },
        "frontmatterfix": {
          "properties": {
            "apply": {
              "default": false,
              "description": "Apply changes (default: dry-run)",
              "type": "boolean"
            },
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "vault": {
              "default": ".",
              "description": "Path to vault root",
              "type": "string"
            }
          },
          "type": "object"
        },
        "frontmattermerge": {
          "properties": {
            "allow_extra": {
              "default": false,
              "description": "Allow keys not in type schema",
              "type": "boolean"
            },
            "commit": {
              "default": false,
              "description": "Stage and commit after mutation",
              "type": "boolean"
            },
            "diff": {
              "default": false,
              "description": "Show unified diff",
              "type": "boolean"
            },
            "dry_run": {
              "default": false,
              "description": "Preview changes without writing",
              "type": "boolean"
            },
            "file": {
              "default": "",
              "description": "YAML file with fields to merge",
              "type": "string"
            },
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "vault": {
              "default": ".",
              "description": "Path to vault root",
              "type": "string"
            }
          },
          "type": "object"
        },
        "frontmatternormalize": {
          "properties": {
            "commit": {
              "default": false,
              "description": "Stage and commit after mutation",
              "type": "boolean"
            },
            "diff": {
              "default": false,
              "description": "Show unified diff",
              "type": "boolean"
            },
            "dry_run": {
              "default": false,
              "description": "Preview changes without writing",
              "type": "boolean"
            },
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "strip_time": {
              "default": false,
              "description": "Force all datetimes to date-only",
              "type": "boolean"
            },
            "vault": {
              "default": ".",
              "description": "Path to vault root",
              "type": "string"
            }
          },
          "type": "object"
        },
        "frontmatterset": {
          "properties": {
            "allow_extra": {
              "default": false,
              "description": "Allow keys not in type schema",
              "type": "boolean"
            },
            "commit": {
              "default": false,
              "description": "Stage and commit after mutation",
              "type": "boolean"
            },
            "diff": {
              "default": false,
              "description": "Show unified diff",
              "type": "boolean"
            },
            "dry_run": {
              "default": false,
              "description": "Preview changes without writing",
              "type": "boolean"
            },
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "vault": {
              "default": ".",
              "description": "Path to vault root",
              "type": "string"
            }
          },
          "type": "object"
        },
        "frontmatterunset": {
          "properties": {
            "commit": {
              "default": false,
              "description": "Stage and commit after mutation",
              "type": "boolean"
            },
            "diff": {
              "default": false,
              "description": "Show unified diff",
              "type": "boolean"
            },
            "dry_run": {
              "default": false,
              "description": "Preview changes without writing",
              "type": "boolean"
            },
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "vault": {
              "default": ".",
              "description": "Path to vault root",
              "type": "string"
            }
          },
          "type": "object"
        },
        "gitstatus": {
          "properties": {
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "vault": {
              "default": ".",
              "description": "Path to vault root",
              "type": "string"
            }
          },
          "type": "object"
        },
        "hooksinstall": {
          "properties": {
            "dryrun": {
              "default": false,
              "description": "With --merge, print the merged result without writing it (preview/diff).",
              "type": "boolean"
            },
            "force": {
              "default": false,
              "description": "Overwrite existing hook scripts (default: refuse)",
              "type": "boolean"
            },
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "local": {
              "default": false,
              "description": "With --merge, target .claude/settings.local.json (gitignored, personal) instead of .claude/settings.json (committed, team-shared).",
              "type": "boolean"
            },
            "merge": {
              "default": false,
              "description": "Additively merge the hook stanza into the project's settings file (never clobbers existing hooks) instead of only printing it.",
              "type": "boolean"
            },
            "only": {
              "default": "",
              "description": "Comma-separated subset of canonical scripts to install (default: all). Unknown names rejected at lint time.",
              "type": "string"
            },
            "vault": {
              "default": "",
              "description": "Vault path to bake into the printed settings.json stanza via VAULTMIND_VAULT (default: the built-in vaultmind-identity convention).",
              "type": "string"
            }
          },
          "type": "object"
        },
        "hooksuninstall": {
          "properties": {
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "local": {
              "default": false,
              "description": "Target .claude/settings.local.json instead of .claude/settings.json.",
              "type": "boolean"
            },
            "removescripts": {
              "default": false,
              "description": "Also delete the installed hook scripts under .claude/scripts/ (default: leave them).",
              "type": "boolean"
            }
          },
          "type": "object"
        },
        "identityinit": {
          "properties": {
            "signer_key": {
              "default": "",
              "description": "Sealed signer key path (default: XDG data dir)",
              "type": "string"
            }
          },
          "type": "object"
        },
        "identitysign": {
          "properties": {
            "file": {
              "default": "",
              "description": "Read entry JSON from this file instead of stdin",
              "type": "string"
            },
            "signer_socket": {
              "default": "",
              "description": "Signer socket path (default: XDG state dir)",
              "type": "string"
            }
          },
          "type": "object"
        },
        "identitysignenvelope": {
          "properties": {
            "file": {
              "default": "",
              "description": "Read envelope JSON from this file instead of stdin",
              "type": "string"
            },
            "from_pubkey": {
              "default": "",
              "description": "Signer public key (base64) stamped as the from_pubkey hint; not signed",
              "type": "string"
            },
            "signer_socket": {
              "default": "",
              "description": "Signer socket path (default: XDG state dir)",
              "type": "string"
            }
          },
          "type": "object"
        },
        "index": {
          "properties": {
            "allow_slow_backend": {
              "default": false,
              "description": "Allow BGE-M3 indexing on the pure-Go backend (hours for medium vaults)",
              "examples": [
                "true"
              ],
              "type": "boolean"
            },
            "embed": {
              "default": false,
              "description": "Compute and store embeddings for note bodies",
              "examples": [
                "true"
              ],
              "type": "boolean"
            },
            "full": {
              "default": false,
              "description": "Force full rebuild instead of incremental index",
              "examples": [
                "true"
              ],
              "type": "boolean"
            },
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "examples": [
                "true"
              ],
              "type": "boolean"
            },
            "model": {
              "default": "",
              "description": "Embedding model: minilm (384d, fast) or bge-m3 (1024d, 3-in-1). Empty (default) auto-selects: bge-m3 on ORT-tagged builds, minilm on pure-Go.",
              "examples": [
                "bge-m3"
              ],
              "type": "string"
            },
            "vault": {
              "default": ".",
              "description": "Path to the vault root directory",
              "examples": [
                "./my-vault"
              ],
              "type": "string"
            }
          },
          "type": "object"
        },
        "init": {
          "properties": {
            "dry_run": {
              "default": false,
              "description": "With --wire-hooks, print the would-be settings merge without writing it (preview).",
              "type": "boolean"
            },
            "full": {
              "default": false,
              "description": "With --print-instructions, print the full agent-onboarding guide instead of the concise quick-start",
              "type": "boolean"
            },
            "local": {
              "default": false,
              "description": "With --wire-hooks, merge into .claude/settings.local.json (gitignored, personal) instead of .claude/settings.json (committed, team-shared).",
              "type": "boolean"
            },
            "print_instructions": {
              "default": false,
              "description": "Print the concise agent-onboarding quick-start and exit (no vault created); add --full for the whole guide",
              "type": "boolean"
            },
            "project_dir": {
              "default": "",
              "description": "With --wire-hooks, the project to wire hooks into (where .claude/ lives). Defaults to the current directory; set it when the vault and the project root differ.",
              "type": "string"
            },
            "wire_hooks": {
              "default": false,
              "description": "After scaffolding, install the Claude Code hook scripts into the current project and merge the wiring into .claude/settings.json (baked to the new vault). Never clobbers existing hooks.",
              "type": "boolean"
            }
          },
          "type": "object"
        },
        "links": {
          "properties": {
            "edge_type": {
              "default": "",
              "description": "Filter by edge type",
              "type": "string"
            },
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "vault": {
              "default": ".",
              "description": "Path to vault root",
              "type": "string"
            }
          },
          "type": "object"
        },
        "linksneighbors": {
          "properties": {
            "depth": {
              "default": 1,
              "description": "Maximum traversal depth",
              "type": "integer"
            },
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "max_nodes": {
              "default": 200,
              "description": "Maximum nodes to return",
              "type": "integer"
            },
            "min_confidence": {
              "default": "low",
              "description": "Minimum edge confidence (low, medium, high)",
              "type": "string"
            },
            "vault": {
              "default": ".",
              "description": "Path to vault root",
              "type": "string"
            }
          },
          "type": "object"
        },
        "lintfixlinks": {
          "properties": {
            "fix": {
              "default": false,
              "description": "Apply fixes (default is dry-run)",
              "type": "boolean"
            },
            "json": {
              "default": false,
              "description": "Output in JSON format",
              "type": "boolean"
            },
            "vault": {
              "default": ".",
              "description": "Path to vault root",
              "type": "string"
            }
          },
          "type": "object"
        },
        "log": {
          "properties": {
            "color_enabled": {
              "default": "auto",
              "description": "Enable colored console output (auto, true, false). Auto detects TTY.",
              "examples": [
                "true"
              ],
              "type": "string"
            },
            "console_level": {
              "default": "",
              "description": "Console log level (trace, debug, info, warn, error, fatal, panic). If empty, uses app.log_level.",
              "examples": [
                "info"
              ],
              "type": "string"
            },
            "file_compress": {
              "default": false,
              "description": "Compress rotated log files with gzip",
              "examples": [
                "true"
              ],
              "type": "boolean"
            },
            "file_enabled": {
              "default": false,
              "description": "Enable file logging to capture detailed logs",
              "examples": [
                "true"
              ],
              "type": "boolean"
            },
            "file_level": {
              "default": "debug",
              "description": "File log level (trace, debug, info, warn, error, fatal, panic)",
              "examples": [
                "debug"

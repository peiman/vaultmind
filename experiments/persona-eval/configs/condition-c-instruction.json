{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.ckeletin/scripts/install_tools.sh"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/experiments/persona-eval/scripts/inject-instruction.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.ckeletin/scripts/check-commit-msg.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(task *)",
      "Bash(go test:*)",
      "Bash(git:*)",
      "Bash(go build:*)",
      "Bash(go run:*)",
      "Bash(grep -n \"Template\" /Users/peiman/dev/cli/vaultmind/.worktrees/p3d-note-create/internal/vault/*.go)",
      "Bash(grep -n \"NewIndexer\\\\|cfg.Index.DBPath\" /Users/peiman/dev/cli/vaultmind/.worktrees/p3d-note-create/cmd/*.go)",
      "Bash(awk 'NR==24,NR==29' /Users/peiman/dev/cli/vaultmind/.worktrees/p3d-note-create/cmd/note_create.go)",
      "Bash(python3 -c \"import sys,json; d=json.load\\(sys.stdin\\); r=d['result']; print\\(f'id={r[\\\\\"id\\\\\"]} type={r[\\\\\"type\\\\\"]} path={r[\\\\\"path\\\\\"]} created={r[\\\\\"created\\\\\"]}'\\)\")",
      "Bash(time /tmp/vm memory recall proj-vaultmind --vault /Users/peiman/dev/cli/vaultmind/vaultmind-vault --depth 3 --json)",
      "Bash(python3 -c \"import json,sys; d=json.load\\(sys.stdin\\); print\\(f'Nodes: {len\\(d[\\\\\"result\\\\\"][\\\\\"nodes\\\\\"]\\)}, Edges: {len\\(d[\\\\\"result\\\\\"][\\\\\"edges\\\\\"]\\)}'\\)\")",
      "Bash(/tmp/vm memory:*)",
      "Bash(/tmp/vm note:*)",
      "Bash(/tmp/vm frontmatter:*)",
      "Bash(echo \"EXIT: $?\")",
      "Bash(/tmp/vm vault:*)",
      "Bash(python3 -c ':*)",
      "Bash(python3 -c \"import json,sys; d=json.load\\(sys.stdin\\); print\\(f'depth=2: nodes={len\\(d[\\\\\"result\\\\\"][\\\\\"nodes\\\\\"]\\)}, edges={len\\(d[\\\\\"result\\\\\"][\\\\\"edges\\\\\"]\\)}'\\)\")",
      "Bash(python3 -c \"import json,sys; d=json.load\\(sys.stdin\\); print\\(f'depth=3: nodes={len\\(d[\\\\\"result\\\\\"][\\\\\"nodes\\\\\"]\\)}, edges={len\\(d[\\\\\"result\\\\\"][\\\\\"edges\\\\\"]\\)}'\\)\")",
      "Bash(python3 -c \"import json,sys; d=json.load\\(sys.stdin\\); print\\(f'depth=1: nodes={len\\(d[\\\\\"result\\\\\"][\\\\\"nodes\\\\\"]\\)}, edges={len\\(d[\\\\\"result\\\\\"][\\\\\"edges\\\\\"]\\)}'\\)\")",
      "Bash(/tmp/vm links:*)",
      "Bash(sqlite3:*)",
      "Bash(/tmp/vm resolve:*)",
      "Bash(/tmp/vm index:*)",
      "Bash(/tmp/vm apply:*)",
      "Bash(/tmp/vm search:*)",
      "Bash(go get:*)",
      "Bash(go mod:*)",
      "Bash(/tmp/vaultmind index:*)",
      "Bash(/tmp/vaultmind search:*)",
      "Bash(/tmp/vaultmind resolve:*)",
      "Bash(/tmp/vaultmind note:*)",
      "Bash(/tmp/vaultmind memory:*)",
      "Bash(/tmp/vaultmind links:*)",
      "Bash(/tmp/vaultmind frontmatter:*)",
      "Bash(/tmp/vaultmind dataview:*)",
      "Bash(/tmp/vaultmind vault:*)",
      "Bash(/tmp/vaultmind doctor:*)",
      "Bash(/tmp/vaultmind schema:*)",
      "Bash(/tmp/vaultmind git:*)",
      "WebSearch",
      "Bash(wait)",
      "Bash(./vaultmind memory:*)",
      "Bash(python3 -m json.tool)",
      "Bash(./vaultmind search:*)",
      "Bash(find ./internal ./cmd -name \"*.go\" -type f -exec grep -l \"package\\\\|func\" {} \\\\;)",
      "Bash(go fmt:*)",
      "Bash(/tmp/vaultmind ask:*)",
      "Bash(./vaultmind check:*)",
      "Bash(gh api:*)",
      "Bash(curl -sL \"https://api.github.com/repos/nlpodyssey/gopickle/tags?per_page=5\")",
      "Bash(python3 -c \"import sys,json; [print\\(x['name']\\) for x in json.load\\(sys.stdin\\)]\")",
      "Bash(curl -sL \"https://api.github.com/repos/nlpodyssey/gopickle/commits?per_page=5\")",
      "Bash(python3 -c \"import sys,json; [print\\(f'{x[\\\\\"sha\\\\\"][:8]}: {x[\\\\\"commit\\\\\"][\\\\\"message\\\\\"].split\\(chr\\(10\\)\\)[0]} \\({x[\\\\\"commit\\\\\"][\\\\\"committer\\\\\"][\\\\\"date\\\\\"]}\\)'\\) for x in json.load\\(sys.stdin\\)]\")",
      "Skill(pr-review-toolkit:review-pr)",
      "Bash(xargs cat:*)",
      "Bash(bash /Users/peiman/dev/cli/vaultmind/.claude/scripts/load-persona.sh)"
    ]
  },
  "disabledMcpjsonServers": [
    "rlm"
  ]
}
